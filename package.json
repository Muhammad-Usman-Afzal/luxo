{
  "name": "bazaarhub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:backend": "dotnet watch run --project BazaarHub.Backend/BazaarHub.Backend.csproj",
    "dev:full": "concurrently -n frontend,backend -c blue,green \"npm run dev\" \"npm run dev:backend\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run dev:full"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "^1.14.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "^7.15.0",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.17",
    "typescript": "5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
